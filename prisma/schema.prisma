generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(100)
  status      TenantStatus @default(ACTIVE)
  plan        PlanTier @default(FREE)
  logo        String?  @db.Text
  website     String?  @db.VarChar(500)
  country     String?  @db.VarChar(50)
  timezone    String   @default("UTC") @db.VarChar(50)
  storageUsed BigInt   @default(0) @db.BigInt
  storageLimit BigInt  @default(1073741824) @db.BigInt
  userCount   Int      @default(0)
  userLimit   Int      @default(1)
  createdAt   DateTime @default(now()) @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @db.Timestamp(0)
  trialEndsAt DateTime? @db.Timestamp(0)

  users         User[]
  subscriptions Subscription[]
  jobs          Job[]
  diskImages    DiskImage[]
  apiKeys       ApiKey[]
  webhooks      Webhook[]
  auditLogs     AuditLog[]
  userInvites   UserInvite[]
  recoveryJobs   RecoveryJob[]
  forensicCases  ForensicCase[]

  @@index([slug])
  @@index([status])
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TRIAL
}

enum PlanTier {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique @db.VarChar(255)
  passwordHash     String   @db.VarChar(255)
  firstName        String   @db.VarChar(100)
  lastName         String   @db.VarChar(100)
  avatar           String?  @db.Text
  role             UserRole @default(MEMBER)
  status           UserStatus @default(ACTIVE)
  emailVerified    Boolean  @default(false)
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?  @db.VarChar(255)
  createdAt        DateTime @default(now()) @db.Timestamp(0)
  updatedAt        DateTime @updatedAt @db.Timestamp(0)
  lastLoginAt      DateTime? @db.Timestamp(0)

  tenantId         String?
  tenant           Tenant?  @relation(fields: [tenantId], references: [id])
  
  sessions         Session[]
  refreshTokens    RefreshToken[]
  passwordResets   PasswordReset[]
  auditLogs        AuditLog[]
  jobs             Job[]
  recoveryJobs     RecoveryJob[]

  @@index([email])
  @@index([tenantId])
  @@index([status])
}

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  FORENSIC_ANALYST
  RECOVERY_TECHNICIAN
  SUPPORT_ENGINEER
  BILLING_ADMIN
  TEAM_MANAGER
  MEMBER
  GUEST
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?  @db.VarChar(45)
  userAgent String?  @db.Text
  createdAt DateTime @default(now()) @db.Timestamp(0)
  expiresAt DateTime @db.Timestamp(0)

  @@index([userId])
  @@index([expiresAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique @db.VarChar(255)
  createdAt DateTime @default(now()) @db.Timestamp(0)
  expiresAt DateTime @db.Timestamp(0)
  revokedAt DateTime? @db.Timestamp(0)

  @@index([userId])
  @@index([tokenHash])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique @db.VarChar(255)
  expiresAt DateTime @db.Timestamp(0)
  usedAt    DateTime? @db.Timestamp(0)
  createdAt DateTime @default(now()) @db.Timestamp(0)

  @@index([userId])
}

model Job {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  name         String    @db.VarChar(255)
  description  String?   @db.Text
  status       JobStatus @default(PENDING)
  type         JobType
  sourceType   SourceType
  sourceId     String?   @db.VarChar(255)
  progress     Int       @default(0)
  filesFound   Int       @default(0)
  filesRecovered Int     @default(0)
  storageUsed  BigInt    @default(0) @db.BigInt
  fileSystem   FileSystemType?
  startedAt    DateTime? @db.Timestamp(0)
  completedAt  DateTime? @db.Timestamp(0)
  error        String?   @db.Text
  settings     Json      @default("{}")
  createdAt    DateTime  @default(now()) @db.Timestamp(0)
  updatedAt    DateTime  @updatedAt @db.Timestamp(0)

  diskImage    DiskImage? @relation(fields: [diskImageId], references: [id])
  diskImageId  String?
  files        RecoveredFile[]
  recoveryJobs RecoveryJob[]

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum JobStatus {
  PENDING
  QUEUED
  SCANNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum JobType {
  QUICK_SCAN
  DEEP_SCAN
  SIGNATURE_SCAN
  CARVING
  RAID_RECOVERY
  PARTITION_RECOVERY
  CLOUD_BACKUP
  FORENSIC
  CORRUPTED_DISK_ANALYSIS
  CLONE_DAMAGED_DISK
  FILESYSTEM_REPAIR
  SSD_ANALYSIS
  MEMORY_FORENSICS
  TIMELINE_GENERATION
  REGISTRY_ANALYSIS
  BROWSER_FORENSICS
  EMAIL_ANALYSIS
  NETWORK_ANALYSIS
  YARA_SCAN
  IOC_EXTRACTION
  STEGANALYSIS
  ENCRYPTION_DETECTION
  MOBILE_FORENSICS
}

enum SourceType {
  UPLOAD
  AGENT
  CLOUD
  CORRUPTED_DISK
  RAID_ARRAY
  SSD_NVME
  MOBILE_DEVICE
  MEMORY_DUMP
}

enum FileSystemType {
  NTFS
  FAT32
  EXFAT
  EXT2
  EXT3
  EXT4
  XFS
  BTRFS
  HFS_PLUS
  APFS
  UNKNOWN
}

enum RecoverySource {
  LOCAL_DISK
  EXTERNAL_DISK
  DISK_IMAGE
  CLOUD_STORAGE
  NETWORK_SHARE
  MEMORY_DUMP
  CORRUPTED_DISK
  RAID_ARRAY
  SSD_NVME
  MOBILE_DEVICE
}

model DiskImage {
  id           String        @id @default(cuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  name         String        @db.VarChar(255)
  originalName String        @db.VarChar(255)
  size         BigInt        @db.BigInt
  hash         String        @db.VarChar(255)
  fileSystem   FileSystemType?
  partitions   Json          @default("[]")
  uploadedAt   DateTime      @default(now()) @db.Timestamp(0)
  processedAt  DateTime?     @db.Timestamp(0)
  status       ImageStatus   @default(UPLOADING)
  url          String?       @db.Text

  jobs         Job[]

  @@index([tenantId])
  @@index([hash])
}

enum ImageStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
}

model RecoveredFile {
  id                  String   @id @default(cuid())
  jobId               String
  job                 Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name                String   @db.VarChar(255)
  originalPath        String   @db.Text
  currentPath         String?  @db.Text
  size                BigInt   @db.BigInt
  type                String   @db.VarChar(50)
  extension           String   @db.VarChar(20)
  hash                String?  @db.VarChar(255)
  recoverable         Boolean  @default(true)
  recoveryProbability Int
  isFragmented        Boolean  @default(false)
  createdAt           DateTime @default(now()) @db.Timestamp(0)
  modifiedAt          DateTime? @db.Timestamp(0)
  deletedAt           DateTime? @db.Timestamp(0)
  previewAvailable    Boolean  @default(false)
  metadata            Json     @default("{}")

  @@index([jobId])
  @@index([type])
}

model UserInvite {
  id          String        @id @default(cuid())
  email       String        @db.VarChar(255)
  role        UserRole
  department  String?       @db.VarChar(100)
  status      InviteStatus  @default(PENDING)
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  invitedBy   String
  expiresAt   DateTime      @db.Timestamp(0)
  createdAt   DateTime      @default(now()) @db.Timestamp(0)

  @@index([tenantId])
  @@index([email])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

model RecoveryJob {
  id           String            @id @default(cuid())
  sourceJobId  String
  sourceJob    Job              @relation(fields: [sourceJobId], references: [id])
  userId       String
  user         User              @relation(fields: [userId], references: [id])
  status       RecoveryStatus   @default(PENDING)
  totalSize   BigInt           @default(0) @db.BigInt
  destination  Json
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  createdAt   DateTime         @default(now()) @db.Timestamp(0)
  completedAt  DateTime?        @db.Timestamp(0)

  @@index([tenantId])
  @@index([sourceJobId])
}

enum RecoveryStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Subscription {
  id                   String             @id @default(cuid())
  tenantId             String             @unique
  tenant               Tenant             @relation(fields: [tenantId], references: [id])
  planId               String             @db.VarChar(50)
  plan                 PlanTier
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime           @db.Timestamp(0)
  currentPeriodEnd     DateTime           @db.Timestamp(0)
  cancelAtPeriodEnd    Boolean            @default(false)
  cancelledAt          DateTime?          @db.Timestamp(0)
  trialEndsAt          DateTime?          @db.Timestamp(0)
  stripeSubscriptionId String?            @db.VarChar(255)
  stripeCustomerId     String?            @db.VarChar(255)
  createdAt            DateTime           @default(now()) @db.Timestamp(0)
  updatedAt            DateTime           @updatedAt @db.Timestamp(0)

  @@index([tenantId])
  @@index([status])
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String   @db.VarChar(100)
  resource    String   @db.VarChar(100)
  resourceId  String?  @db.VarChar(255)
  metadata    Json?
  ipAddress   String?  @db.VarChar(45)
  userAgent   String?  @db.Text
  timestamp   DateTime @default(now()) @db.Timestamp(0)

  @@index([tenantId])
  @@index([userId])
  @@index([timestamp])
  @@index([action])
}

model ApiKey {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String   @db.VarChar(100)
  keyHash     String   @unique @db.VarChar(255)
  keyPrefix   String   @db.VarChar(20)
  permissions Json     @default("[]")
  lastUsedAt  DateTime? @db.Timestamp(0)
  expiresAt   DateTime? @db.Timestamp(0)
  createdAt   DateTime @default(now()) @db.Timestamp(0)

  @@index([tenantId])
  @@index([keyHash])
}

model Webhook {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  url       String   @db.Text
  events    Json     @default("[]")
  secret    String   @db.VarChar(255)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamp(0)

  @@index([tenantId])
}

// ========================================
// CASE MANAGEMENT & EVIDENCE TABLES
// ========================================

model ForensicCase {
  id             String     @id @default(cuid())
  caseNumber     String     @unique @db.VarChar(100)
  name           String     @db.VarChar(255)
  description    String?    @db.Text
  status         CaseStatus @default(OPEN)
  priority       Priority   @default(MEDIUM)
  tenantId       String
  tenant         Tenant     @relation(fields: [tenantId], references: [id])
  investigatorId String
  tags           Json       @default("[]")
  metadata       Json       @default("{}")
  createdAt      DateTime   @default(now()) @db.Timestamp(0)
  updatedAt      DateTime   @updatedAt @db.Timestamp(0)

  evidence       Evidence[]
  timelineEvents TimelineEvent[]
  auditLogs      AuditLog[]

  @@index([tenantId])
  @@index([status])
  @@index([caseNumber])
  @@index([createdAt])
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Evidence {
  id              String         @id @default(cuid())
  caseId          String
  case            ForensicCase   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  filename        String         @db.VarChar(500)
  description     String?        @db.Text
  evidenceType    EvidenceType   @default(FILE)
  filePath        String?        @db.Text
  fileSize        BigInt?        @db.BigInt
  hashMD5         String?        @db.VarChar(255)
  hashSHA256      String?        @db.VarChar(255)
  collectedBy     String         @db.VarChar(255)
  collectedAt     DateTime       @db.Timestamp(0)
  location        String?        @db.VarChar(500)
  notes           String?        @db.Text
  status          EvidenceStatus @default(COLLECTED)
  chainOfCustody  Json           @default("[]")
  metadata        Json           @default("{}")
  createdAt       DateTime       @default(now()) @db.Timestamp(0)
  updatedAt       DateTime       @updatedAt @db.Timestamp(0)

  @@index([caseId])
  @@index([evidenceType])
  @@index([status])
  @@index([collectedAt])
}

enum EvidenceType {
  FILE
  DISK_IMAGE
  MEMORY_DUMP
  NETWORK_CAPTURE
  DOCUMENT
  PHOTO
  AUDIO
  VIDEO
  OTHER
}

enum EvidenceStatus {
  COLLECTED
  ANALYZING
  ANALYZED
  ARCHIVED
  RETURNED
  DESTROYED
}

// ========================================
// CORRUPTED DISK RECOVERY TABLES
// ========================================

model CorruptedDiskAnalysis {
  id                String   @id @default(cuid())
  jobId             String
  job               Job      @relation(fields: [jobId], references: [id])
  driveModel        String?  @db.VarChar(255)
  driveSerial       String?  @db.VarChar(255)
  driveFirmware     String?  @db.VarChar(100)
  smartStatus       String?  @db.VarChar(50)
  reallocatedSectors Int     @default(0)
  pendingSectors    Int      @default(0)
  uncorrectableSectors Int   @default(0)
  powerOnHours      Int?
  temperature       Int?
  healthStatus      String   @default("unknown") @db.VarChar(50)
  badSectorMap      Json?
  cloneProgress     Int      @default(0)
  cloneStatus       String   @default("pending") @db.VarChar(50)
  clonedImagePath   String?  @db.Text
  analyzedAt        DateTime @default(now()) @db.Timestamp(0)
  
  @@index([jobId])
  @@index([healthStatus])
}

model PartitionRecovery {
  id                String   @id @default(cuid())
  jobId             String
  job               Job      @relation(fields: [jobId], references: [id])
  partitionType     String   @db.VarChar(50)
  originalMbr       Json?
  recoveredMbr      Json?
  originalGpt       Json?
  recoveredGpt      Json?
  partitionsFound   Int      @default(0)
  partitionsRecovered Int    @default(0)
  recoveryStatus    String   @default("pending") @db.VarChar(50)
  recoveredAt       DateTime @default(now()) @db.Timestamp(0)
  
  @@index([jobId])
  @@index([partitionType])
}

model FileSystemRepair {
  id                String   @id @default(cuid())
  jobId             String
  job               Job      @relation(fields: [jobId], references: [id])
  fileSystemType    String   @db.VarChar(50)
  repairType        String   @db.VarChar(100)
  originalState     Json?
  repairedState     Json?
  filesRecovered    Int      @default(0)
  directoriesRecovered Int   @default(0)
  repairStatus      String   @default("pending") @db.VarChar(50)
  repairedAt        DateTime @default(now()) @db.Timestamp(0)
  
  @@index([jobId])
  @@index([fileSystemType])
}

model RAIDConfiguration {
  id                String   @id @default(cuid())
  jobId             String
  job               Job      @relation(fields: [jobId], references: [id])
  raidLevel         String   @db.VarChar(50)
  diskCount         Int
  stripeSize        Int?
  diskOrder         Json?
  parityRotation    String?  @db.VarChar(100)
  autoDetected      Boolean  @default(false)
  assembled         Boolean  @default(false)
  virtualArray      Boolean  @default(false)
  assembledImagePath String? @db.Text
  createdAt         DateTime @default(now()) @db.Timestamp(0)
  
  @@index([jobId])
  @@index([raidLevel])
}

model SSDAnalysis {
  id                String   @id @default(cuid())
  jobId             String
  job               Job      @relation(fields: [jobId], references: [id])
  trimEnabled       Boolean?
  wearLevelingCount  Int?
  totalBytesWritten  BigInt? @db.BigInt
  totalBytesRead     BigInt? @db.BigInt
  mediaWearoutIndicator Int?
  overProvisioningSize BigInt? @db.BigInt
  garbageCollectionImpact String? @db.VarChar(100)
  recoverabilityScore Int?
  analyzedAt        DateTime @default(now()) @db.Timestamp(0)
  
  @@index([jobId])
}

// ========================================
// ADVANCED FORENSICS TABLES
// ========================================

model TimelineEvent {
  id                String   @id @default(cuid())
  caseId            String
  timestamp         DateTime @db.Timestamp(0)
  eventType         String   @db.VarChar(100)
  source            String   @db.VarChar(100)
  description       String   @db.Text
  filePath          String?  @db.Text
  registryKey       String?  @db.Text
  eventName         String?  @db.VarChar(255)
  macb              String?  @db.VarChar(10)
  evidenceId        String?  @db.VarChar(255)
  metadata          Json?
  createdAt         DateTime @default(now()) @db.Timestamp(0)
  
  @@index([caseId])
  @@index([timestamp])
  @@index([eventType])
  @@index([source])
}

model RegistryArtifact {
  id                String   @id @default(cuid())
  jobId             String
  job               Job      @relation(fields: [jobId], references: [id])
  hiveName          String   @db.VarChar(100)
  keyPath           String   @db.Text
  valueName         String?  @db.VarChar(255)
  valueType         String?  @db.VarChar(50)
  valueData         String?  @db.Text
  lastModified      DateTime? @db.Timestamp(0)
  artifactType      String   @db.VarChar(100)
  significance      String?  @db.VarChar(50)
  extractedAt       DateTime @default(now()) @db.Timestamp(0)
  
  @@index([jobId])
  @@index([artifactType])
  @@index([hiveName])
}

model BrowserArtifact {
  id                String   @id @default(cuid())
  jobId             String
  job               Job      @relation(fields: [jobId], references: [id])
  browser           String   @db.VarChar(100)
  artifactType      String   @db.VarChar(100)
  url               String?  @db.Text
  title             String?  @db.VarChar(500)
  visitCount        Int      @default(0)
  lastVisit         DateTime? @db.Timestamp(0)
  filePath          String?  @db.Text
  fileSize          BigInt?  @db.BigInt
  metadata          Json?
  extractedAt       DateTime @default(now()) @db.Timestamp(0)
  
  @@index([jobId])
  @@index([browser])
  @@index([artifactType])
}

model EmailArtifact {
  id                String   @id @default(cuid())
  jobId             String
  job               Job      @relation(fields: [jobId], references: [id])
  emailType         String   @db.VarChar(50)
  sender            String?  @db.VarChar(255)
  recipients        Json?
  subject           String?  @db.VarChar(500)
  date              DateTime? @db.Timestamp(0)
  hasAttachments    Boolean  @default(false)
  attachmentCount   Int      @default(0)
  bodyPreview       String?  @db.Text
  headers           Json?
  isPhishing        Boolean  @default(false)
  spamScore         Float?
  extractedAt       DateTime @default(now()) @db.Timestamp(0)
  
  @@index([jobId])
  @@index([sender])
  @@index([date])
  @@index([emailType])
}

model NetworkArtifact {
  id                String   @id @default(cuid())
  jobId             String
  job               Job      @relation(fields: [jobId], references: [id])
  artifactType      String   @db.VarChar(100)
  protocol          String?  @db.VarChar(50)
  sourceIP          String?  @db.VarChar(45)
  destinationIP     String?  @db.VarChar(45)
  sourcePort        Int?
  destinationPort   Int?
  timestamp         DateTime? @db.Timestamp(0)
  payloadSize       BigInt?  @db.BigInt
  extractedFiles    Json?
  credentials       Json?
  suspicious        Boolean  @default(false)
  metadata          Json?
  extractedAt       DateTime @default(now()) @db.Timestamp(0)
  
  @@index([jobId])
  @@index([protocol])
  @@index([artifactType])
}

model YaraScanResult {
  id                String   @id @default(cuid())
  jobId             String
  job               Job      @relation(fields: [jobId], references: [id])
  ruleName          String   @db.VarChar(255)
  ruleFile          String?  @db.VarChar(500)
  matchedFile       String   @db.VarChar(500)
  matchedFilePath   String?  @db.Text
  matchedFileSize   BigInt?  @db.BigInt
  matches           Json?
  severity          String   @db.VarChar(50)
  description       String?  @db.Text
  scannedAt         DateTime @default(now()) @db.Timestamp(0)
  
  @@index([jobId])
  @@index([ruleName])
  @@index([severity])
}

model IOCExtract {
  id                String   @id @default(cuid())
  caseId            String
  iocType           String   @db.VarChar(100)
  iocValue          String   @db.Text
  source            String?  @db.VarChar(255)
  sourcePath        String?  @db.Text
  confidence        Int
  firstSeen         DateTime? @db.Timestamp(0)
  lastSeen          DateTime? @db.Timestamp(0)
  relatedEvents     Json?
  tags              Json?
  createdAt         DateTime @default(now()) @db.Timestamp(0)
  
  @@index([caseId])
  @@index([iocType])
  @@index([iocValue])
}

model MemoryAnalysis {
  id                String   @id @default(cuid())
  jobId             String
  job               Job      @relation(fields: [jobId], references: [id])
  dumpType          String   @db.VarChar(100)
  osVersion         String?  @db.VarChar(100)
  architecture      String?  @db.VarChar(20)
  processCount      Int      @default(0)
  networkConnections Int     @default(0)
  malwareDetections Int      @default(0)
  cryptoKeys        Json?
  clipboardData     String?  @db.Text
  analysisPlugins   Json?
  analyzedAt        DateTime @default(now()) @db.Timestamp(0)
  
  @@index([jobId])
  @@index([dumpType])
}

model SteganalysisResult {
  id                String   @id @default(cuid())
  jobId             String
  job               Job      @relation(fields: [jobId], references: [id])
  filePath          String   @db.Text
  fileName          String   @db.VarChar(500)
  fileSize          BigInt   @db.BigInt
  analysisMethod    String   @db.VarChar(100)
  result            String   @db.VarChar(50)
  confidence        Int
  hiddenDataSize    BigInt?  @db.BigInt
  details           Json?
  analyzedAt        DateTime @default(now()) @db.Timestamp(0)
  
  @@index([jobId])
  @@index([result])
  @@index([analysisMethod])
}

model EncryptionDetection {
  id                String   @id @default(cuid())
  jobId             String
  job               Job      @relation(fields: [jobId], references: [id])
  volumePath        String   @db.Text
  encryptionType    String?  @db.VarChar(100)
  encrypted         Boolean  @default(false)
  entropy           Float?
  headerFound       Boolean  @default(false)
  keyFound          Boolean  @default(false)
  recoverable       Boolean  @default(false)
  details           Json?
  detectedAt        DateTime @default(now()) @db.Timestamp(0)
  
  @@index([jobId])
  @@index([encryptionType])
}
